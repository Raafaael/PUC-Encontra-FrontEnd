{
  "name": "puc-encontra-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/styles.css','dist/styles.css')\"",
    "watch": "tsc --watch",
    "serve": "serve . --single --listen tcp://127.0.0.1:5173",
    "dev": "npm run build && npm run serve"
  },
  "devDependencies": {
    "serve": "^14.2.4",
    "typescript": "^5.5.0"
  }
}
