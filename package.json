{
  "name": "puc-encontra-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.scripts.json && node .build-scripts/build-assets.js",
    "watch": "tsc --watch",
    "serve": "serve . --single --listen tcp://127.0.0.1:5173",
    "dev": "npm run build && npm run serve"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "serve": "^14.2.4",
    "typescript": "^5.5.0"
  }
}
